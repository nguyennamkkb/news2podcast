# ========== Docker Environment ==========
# File này chỉ dùng trong container, KHÔNG thay đổi .env local

# LLM
LLM_PROVIDER=ollama
OLLAMA_API_URL=https://your-ollama-cloud.com/api/generate
OLLAMA_MODEL=qwen3:32b
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Database (dùng service name thay localhost)
DATABASE_URL=postgresql+asyncpg://news2video:news2video@postgres:5432/news2video

# Redis (dùng service name thay localhost)
REDIS_URL=redis://redis:6379/0

# MinIO (dùng service name thay localhost)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=news2video

# Temporal (dùng service name thay localhost)
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default

# App
SECRET_KEY=dev-secret-key
ENVIRONMENT=development
LOG_LEVEL=debug
CORS_ORIGINS=["http://localhost:3000"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
