# LLM Provider: "ollama" hoặc "openai"
LLM_PROVIDER=ollama

# Ollama (khi LLM_PROVIDER=ollama)
OLLAMA_API_URL=https://your-ollama-cloud.com/api/generate
OLLAMA_MODEL=qwen3:32b

# OpenAI-compatible (khi LLM_PROVIDER=openai)
# Dùng cho: OpenAI, Groq, Together AI, LM Studio, Ollama OpenAI endpoint, v.v.
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=sk-your-api-key
LLM_MODEL=gpt-4o-mini

# Database
DATABASE_URL=postgresql+asyncpg://news2video:news2video@localhost:5432/news2video

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=news2video

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=news2video

# App
SECRET_KEY=dev-secret-key-change-in-production
ENVIRONMENT=development
LOG_LEVEL=debug
CORS_ORIGINS=["http://localhost:3000"]